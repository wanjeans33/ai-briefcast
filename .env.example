# AI Briefcast 凭据模板
# 用法：复制为 .env 并填入真实值（.env 已被 gitignore，不会提交）
#   cp .env.example .env
# scripts/doubao_tts_ws.py 和 scripts/run_daily.py 会自动读取仓库根目录的 .env

# --- 改写：pi agent 的 DeepSeek provider（也可被 --llm api 直连复用）---
DEEPSEEK_API_KEY=sk-xxxxxxxx

# --- TTS：火山引擎豆包语音 ---
VOLC_APP_ID=你的appid
VOLC_API_KEY=你的api-key
# 预置/备用音色
VOLC_SPEAKER=S_xxxxxxxx
# 你的克隆音色（声音复刻）。run_daily 默认优先用它，所以每日播报就是你的声音
VOLC_SPEAKER2=S_yyyyyyyy
# 可选，默认 seed-icl-2.0
VOLC_RESOURCE_ID=seed-icl-2.0
